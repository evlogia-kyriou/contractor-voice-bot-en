{
  "title": "Contractor Voice Bot - EN",
  "uid": "contractor-voice-bot-en",
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "title": "Total Calls",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "voice_bot_calls_total",
          "legendFormat": "Total Calls"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area"
      }
    },
    {
      "id": 2,
      "title": "Total Bookings",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "voice_bot_bookings_total",
          "legendFormat": "Bookings"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area"
      }
    },
    {
      "id": 3,
      "title": "Active Calls",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "voice_bot_active_calls",
          "legendFormat": "Active"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none"
      }
    },
    {
      "id": 4,
      "title": "RAG RougeL Score",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "voice_bot_rag_rouge_score",
          "legendFormat": "RougeL"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none"
      }
    },
    {
      "id": 5,
      "title": "Intent Distribution",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "voice_bot_intent_total",
          "legendFormat": "{{intent}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Agent Invocations",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "voice_bot_agent_total",
          "legendFormat": "{{agent}}"
        }
      ]
    },
    {
      "id": 7,
      "title": "Response Latency by Agent (p50)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(voice_bot_response_latency_seconds_bucket[5m]))",
          "legendFormat": "p50 {{agent}}"
        },
        {
          "expr": "histogram_quantile(0.95, rate(voice_bot_response_latency_seconds_bucket[5m]))",
          "legendFormat": "p95 {{agent}}"
        }
      ]
    },
    {
      "id": 8,
      "title": "SMS Notifications Sent",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "rate(voice_bot_sms_total[5m])",
          "legendFormat": "{{channel}} - {{recipient}}"
        }
      ]
    }
  ],
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s"
}
