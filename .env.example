# =============================================================
# LLM BACKEND
# Switch between "ollama" (local) and "openai" (API fallback)
# =============================================================
LLM_BACKEND=ollama

OLLAMA_BASE_URL=http://192.168.x.x:11434
OLLAMA_MODEL_EN=llama3.1:8b


OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# =============================================================
# TWILIO
# =============================================================
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token-here
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx



# =============================================================
# GOOGLE CALENDAR
# =============================================================
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/oauth/callback
GOOGLE_CALENDAR_ID=primary


# =============================================================
# OBSERVABILITY
# =============================================================
PHOENIX_HOST=http://localhost
PHOENIX_PORT=6006

MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_EN=contractor-voice-bot-en


PROMETHEUS_PORT=8001
GRAFANA_PORT=3000

# =============================================================
# APP
# =============================================================
APP_HOST=0.0.0.0
APP_PORT=8000
ENV=development

# Contractor config (hardcoded for pilot, one contractor)
CONTRACTOR_NAME=your-contractor-name
CONTRACTOR_PHONE=+1xxxxxxxxxx
CONTRACTOR_NOTIFICATION_CHANNEL=sms